# =============================================================================
# Missing Link — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/missinglink?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Garmin (https://developer.garmin.com/)
GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""

# Wahoo (https://developers.wahooligan.com/)
WAHOO_CLIENT_ID=""
WAHOO_CLIENT_SECRET=""

# Google Maps (for route/location features)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
